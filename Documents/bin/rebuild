#!/usr/bin/env bash

set -uo pipefail
IFS=$'\n\t'

if [[ "${BASH_SOURCE[0]}" = "$0" ]]; then

  force=0
  if [ "$#" -gt 0 ] && [ "$1" = "-f" ]; then
    force=1
    shift
  fi
  if [ "$#" -gt 1 ]; then
    echo "Label should be one word"
    exit 1
  fi

  # cd to the dotfiles root
  pushd "$HOME"/.dotfiles/ >/dev/null || exit 1

  # check changes
  git --git-dir=dotfiles.git --work-tree="$HOME" diff --quiet nixos
  diff=$?
  new_files=$(git --git-dir=dotfiles.git --work-tree="$HOME" ls-files --others nixos)
  if [ -z "$new_files" ] && [ "$diff" -eq "0" ] && [ "$force" -eq 0 ]; then
    echo "Nothing to rebuild"
    popd >/dev/null || exit 1
    exit 0
  fi

  # Set label
  if [ "$#" -ne 0 ]; then
    label="$1"
  else
    label=""
  fi

  # format files
  alejandra --quiet nixos

  if [[ "$label" != "" ]]; then
    # show diff
    git --git-dir=dotfiles.git --work-tree="$HOME" diff nixos | bat --paging always
  fi

  if [ "$label" == "test" ]; then
    echo "NixOS test building ..."
  elif [ "$label" == "boot" ]; then
    echo "NixOS boot building ..."
  elif [ -n "$label" ]; then
    echo "NixOS rebuilding as '$label' ..."
  else
    echo "NixOS rebuilding ..."
  fi

  build_command="switch"
  if [ "$label" == "test" ]; then
    build_command="test"
  elif [ "$label" == "boot" ]; then
    build_command="boot"
  fi
  sudo NIXOS_LABEL="$label" nixos-rebuild "$build_command" -K --flake "$HOME/.dotfiles/nixos#$(hostname)" 2>&1 | tee /tmp/nixos-switch.log
  success=$?
  if [ "$success" -ne 0 ]; then
    echo -e "\n\n"
    grep --only-matching -P 'error: .+' /tmp/nixos-switch.log | grep --color "error:"
    if [ -x "$(command -v notify-send)" ]; then
      notify-send -e "NixOS Rebuild Failed" --icon=dialog-error
    fi
    exit 1
  fi

  current=$(nixos-rebuild list-generations --keep-going | grep current | awk -F ' ' '{print $5}')
  echo "NixOS Rebuilt as $red$current$reset"
  if [ -n "$label" ] && [ "$label" != "." ] && [ "$label" == "switch" ]; then
    git --git-dir=dotfiles.git --work-tree="$HOME" add nixos
  fi

  popd >/dev/null || exit 1
  if [ -x "$(command -v notify-send)" ]; then
    notify-send -e "NixOS Rebuild Complete" --icon=face-smile
  fi
fi
